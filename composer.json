{
    "type": "project",
    "license": "Apache-2.0",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.0.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "beberlei/doctrineextensions": "^1.5",
        "doctrine/dbal": "^4.4.3",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4.0.0",
        "doctrine/orm": "^3.6.3",
        "easycorp/easyadmin-bundle": "^5.0.5",
        "kartik-v/php-date-formatter": "^1.3",
        "nelmio/cors-bundle": "^2.6.1",
        "phpdocumentor/reflection-docblock": "^6.0.3",
        "phpstan/phpdoc-parser": "^2.3.2",
        "survos/command-bundle": "2.0.203",
        "symfony/asset": "8.0",
        "symfony/asset-mapper": "8.0",
        "symfony/console": "8.0",
        "symfony/doctrine-messenger": "8.0",
        "symfony/dom-crawler": "8.0",
        "symfony/dotenv": "8.0",
        "symfony/expression-language": "8.0",
        "symfony/flex": "^2.5",
        "symfony/form": "8.0",
        "symfony/framework-bundle": "8.0",
        "symfony/http-client": "8.0",
        "symfony/http-kernel": "8.0",
        "symfony/intl": "8.0",
        "symfony/mailer": "8.0",
        "symfony/mime": "8.0",
        "symfony/monolog-bundle": "*",
        "symfony/notifier": "8.0",
        "symfony/polyfill-mbstring": "^1.31",
        "symfony/process": "8.0",
        "symfony/property-access": "8.0",
        "symfony/property-info": "8.0",
        "symfony/runtime": "8.0",
        "symfony/security-bundle": "8.0",
        "symfony/serializer": "8.0",
        "symfony/stimulus-bundle": "^2.23",
        "symfony/string": "8.0",
        "symfony/translation": "8.0",
        "symfony/twig-bundle": "8.0",
        "symfony/ux-autocomplete": "^2.23",
        "symfony/validator": "8.0",
        "symfony/web-link": "8.0",
        "symfony/yaml": "8.0",
        "symfonycasts/sass-bundle": "*",
        "twbs/bootstrap": "^5.3",
        "twig/extra-bundle": "^3.24",
        "twig/intl-extra": "^3.24",
        "twig/twig": "^3.24"
    },
    "config": {
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0"
        }
    },
    "require-dev": {
        "ajgl/breakpoint-twig-extension": "^0.4.3",
        "friendsofphp/php-cs-fixer": "^3.90",
        "phpunit/phpunit": "^9.6.22",
        "symfony/browser-kit": "8.0",
        "symfony/css-selector": "8.0",
        "symfony/debug-bundle": "8.0",
        "symfony/maker-bundle": "^1.63",
        "symfony/phpunit-bridge": "^7.3",
        "symfony/stopwatch": "8.0",
        "symfony/web-profiler-bundle": "8.0"
    }
}
